# Supabase project URL (Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Use the service_role key for server-side access (bypasses RLS). Keep secret.
SUPABASE_SERVICE_KEY=your-service-role-key

# Required for /api/admin/* routes (send header: X-Admin-Key: <value>)
ADMIN_API_KEY=change-me-to-a-long-random-string

# Comma-separated origins (default covers Vite dev). On Railway, include your Vercel URL(s), e.g.
# https://your-app.vercel.app,https://your-app-*.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Railway sets PORT and runs: uvicorn app.main:app --host 0.0.0.0 --port $PORT (see backend/Procfile).
# No backend/.env file is required on Railway if these variables are set in the project dashboard.
